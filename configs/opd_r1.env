# configs/opd_r1.env — Lightning-OPD on-policy-distillation recipe (pipelines/distill.sh).
# 4-phase loop: gen (student rollouts) -> score (BF16 teacher top-k logprobs) ->
# train (FSDP2 rank-16 expert-LoRA via STE + reverse-KL) -> merge (bake + re-quantize).
# Footprint stays ~47 GB (LoRA is merged into the 3b base and re-quantized).
#
# Target DOMAIN matters: train on the gap's domain. The known recoverable gap is LiveCodeBench v6
# (clip token-inefficient -> truncation), so for the code gap point gen at competitive-programming
# CoT, NOT math (math has ~zero headroom). The defaults below load math (the original Stage-2 seed);
# override OPD_PROMPTS / the opd_gen loader for the code gap. See docs/MOE_FINDINGS.md F9 + LADDER.

: "${STU:=models/q122_ptq3b_clip}"   # the 3b-quant student seed
: "${TEA:=Qwen/Qwen3.5-122B-A10B}"                          # BF16 teacher
: "${S:=results/stage2}"                                     # phase-output dir (rollouts.jsonl, teacher_lp.npz)
: "${MODELS_DIR:=models}"
: "${OUT:=$MODELS_DIR/q122_opd_r1}"

# Phase A — opd_gen.py (vLLM, EVAL venv): on-policy student rollouts, verified via math_eq on \boxed{}.
: "${GEN_N:=256}"; : "${GEN_K:=4}"; : "${GEN_MAX_TOKENS:=16384}"

# Phase B — opd_score.py (vLLM prefill-only, EVAL venv): teacher top-k logprobs (k=20) per token.
: "${SCORE_K:=20}"; : "${SCORE_MAX_LEN:=18432}"

# Phase C — opd_train_fsdp.py (torchrun nproc=4, TRAIN venv torch2.7): reverse-KL, rank-16 expert-LoRA.
: "${RANK:=16}"; : "${SCALE:=2.0}"; : "${BITS:=3.0}"; : "${GROUP:=128}"
: "${EPOCHS:=1}"; : "${ACCUM:=8}"; : "${LR:=5e-5}"; : "${TRAIN_MAX_LEN:=8192}"; : "${REVERSE:=1}"; : "${TAU:=1.0}"
: "${MASTER_PORT:=29513}"
# Memory: FSDP2 shards the frozen BF16 base (~65.6 GB/GPU resident) + tiny LoRA; chunked reverse-KL
# (VCHUNK=128) bounds the 248K-vocab logit scratch; lmhead kept gathered; vision/MTP freed; no prefetch.
# If forward memory is still tight, the documented next lever is CPUOffloadPolicy (not yet wired) +
# shrinking TRAIN_MAX_LEN. Smoke first with --smoke 2 (pipelines/distill.sh --smoke).
export STU TEA S MODELS_DIR OUT GEN_N GEN_K GEN_MAX_TOKENS SCORE_K SCORE_MAX_LEN
export RANK SCALE BITS GROUP EPOCHS ACCUM LR TRAIN_MAX_LEN REVERSE TAU MASTER_PORT
