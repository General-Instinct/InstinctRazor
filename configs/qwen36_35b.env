# configs/qwen36_35b.env — quantize recipe for Qwen3.6-35B-A3B, the first NEW target beyond the 122B.
# Qwen3.6-35B-A3B reports model_type=qwen3_5_moe (same arch family as Qwen3.5-122B-A10B): fused 3D
# experts, hybrid Gated-DeltaNet + Gated-Attention, a shared expert, multimodal, vocab 248320. So the
# model_type-keyed Qwen35MoeAdapter handles it unchanged — this is essentially a config-only addition.
#
# Scientific question (docs/MOE_FINDINGS.md): does the uniform-INT3 near-losslessness that held at
# 10B-active (122B) still hold at ~3B-active? Fewer active params per token = less capacity to average
# per-expert quant error over, so this is a genuine new datapoint, not a re-run.
#
# ~35B total / ~3B active, ~70 GB BF16 -> fits a SINGLE 80GB GPU (TP=1). Same uniform 3b/4b + clip recipe.

: "${MODEL:=Qwen/Qwen3.6-35B-A3B}"     # verify the exact HF id + model_type at runtime (see pipelines)
: "${EXPERT_BITS:=3.0}"                # all routed experts, int3 per-block
: "${LINEAR_BITS:=4.0}"                # backbone nn.Linear + embed/lm_head, int4 per-block
: "${GROUP:=128}"
: "${CLIP_STEPS:=16}"                  # MSE-optimal per-block clip search (same as the 122B clip)
: "${MAX_MEM_GIB:=76}"                 # single 80GB GPU (weights ~65 GB dequant-bf16)
: "${MODELS_DIR:=models}"
: "${OUT:=$MODELS_DIR/q36_ptq3b_clip}"
export MODEL EXPERT_BITS LINEAR_BITS GROUP CLIP_STEPS MAX_MEM_GIB MODELS_DIR OUT
