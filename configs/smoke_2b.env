# configs/smoke_2b.env — single-GPU end-to-end smoke recipe (pipelines/smoke.sh).
# Runs the SAME code path as the 122B recipe (quant_save.py -> moe_quant.apply_ptq -> vLLM eval)
# on a small DENSE model so anyone can verify the framework works without 4xH100 + the 122B.
#
# What the smoke exercises: model load (with the ImageTextToText->CausalLM fallback), the per-block
# 4-bit LINEAR quant path (iter_quant_linears + clip-search), dequant-save, vLLM reload, and the
# eval harness. A dense model has NO fused expert tensors, so the int3 EXPERT path (iter_expert_tensors)
# is a no-op here — that path is exercised only at 122B scale (verified in build logs: "quantized 96
# expert tensors, 422 linears/embeds"). The smoke verifies the plumbing, not the expert quantizer.

: "${MODEL:=Qwen/Qwen3.5-2B}"          # small dense Qwen3.5; override with SMOKE_MODEL for a different one
: "${MODEL:=${SMOKE_MODEL:-$MODEL}}"
: "${EXPERT_BITS:=3.0}"                # no-op on a dense model (no experts) but kept for recipe parity
: "${LINEAR_BITS:=4.0}"
: "${GROUP:=128}"
: "${CLIP_STEPS:=8}"                   # fewer steps than the 122B recipe (16) — faster smoke
: "${MAX_MEM_GIB:=70}"                 # single GPU
: "${MODELS_DIR:=/tmp/moe-lowbit/models}"
: "${OUT:=$MODELS_DIR/smoke_2b_q4}"

# Smoke eval: a couple of quick text axes at small-n just to confirm the harness produces a number.
# Tokens must be ones vllm_eval8.py understands (mmlu_pro/gpqa/mmmlu/.../math500/humaneval/...).
# NOTE: this is a PLUMBING check (does load->quant->save->vLLM->eval run and emit JSON?), NOT an accuracy
# check. Qwen3.5-2B is a thinking model, so at a small budget it truncates most generations (expected) and
# the accuracy numbers are near-zero/meaningless — that is fine for a smoke. Budget set high enough that some
# generations finish so the numbers are sane; raise further for a real 2B accuracy read.
: "${SMOKE_BENCHMARKS:=mmlu_pro,math500}"
: "${SMOKE_N:=40}"
: "${SMOKE_BUDGET:=16384}"
: "${TP:=1}"                           # single GPU
export MODEL EXPERT_BITS LINEAR_BITS GROUP CLIP_STEPS MAX_MEM_GIB MODELS_DIR OUT SMOKE_BENCHMARKS SMOKE_N SMOKE_BUDGET TP
