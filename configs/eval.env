# configs/eval.env — eval harness defaults (pipelines/eval.sh). Sampling matches the
# Qwen3.5 thinking-mode reference (temp 0.6 / top_p 0.95 / top_k 20, seed 0).

: "${TP:=4}"                           # tensor-parallel across 4xH100
: "${TEMP:=0.6}"; : "${TOP_P:=0.95}"; : "${TOP_K:=20}"; : "${SEED:=0}"

# --- 32k thinking budget (default; knowledge/reasoning axes) ---
: "${MAX_TOKENS:=32768}"
: "${MAX_MODEL_LEN:=40960}"
: "${MAX_NUM_SEQS:=64}"
: "${GPU_MEM:=0.90}"

# --- 64k long-context budget (math / code / HLE — set BUDGET=64k to use these) ---
# MAX_TOKENS_64K=65536  MAX_MODEL_LEN_64K=66560  MAX_NUM_SEQS_64K=16..32  GPU_MEM_64K=0.88
: "${MAX_TOKENS_64K:=65536}"; : "${MAX_MODEL_LEN_64K:=66560}"; : "${MAX_NUM_SEQS_64K:=32}"; : "${GPU_MEM_64K:=0.88}"

# --- ENFORCE-EAGER rule (validated): ---
# Gemma-4 / A4B crash at long context in vLLM 0.22 (NCCL HeartbeatMonitor worker-death) UNLESS
# --enforce-eager is set (disables CUDA graphs, ~7x slower). The Qwen3.5 teacher + clip run
# WITHOUT enforce-eager (fast, no crash). eval.sh sets it automatically for gemma* models.
: "${DISABLE_CUSTOM_ALL_REDUCE:=1}"    # lossless NCCL all-reduce; avoids an IPC race seen on this box

# n per benchmark (the runs in results/ used 500 for knowledge ladder, 200 for LCB-64k, 300 for HLE, 120 for MM):
: "${N_KNOWLEDGE:=500}"; : "${N_LCB:=200}"; : "${N_HLE:=300}"; : "${N_MM:=120}"

# --- VALIDATION-GATE targets (official numbers; a comparison is only trusted once the harness
#     reproduces the relevant model's official number to ~1-2 pt — see docs/EVAL_PROTOCOL.md) ---
#   benchmark         Qwen3.5-122B   A4B
#   MMLU-Pro          86.7           82.6
#   GPQA-Diamond      86.6           82.3
#   HLE (no-tools)    25.3            8.7
#   LiveCodeBench v6  78.9           77.1
#   MMMLU             86.7           86.3
#   tau2-Bench        79.5           68.2
#   MMMU-Pro          76.9           73.8
#   MATH-Vision       86.2           82.4
export TP TEMP TOP_P TOP_K SEED MAX_TOKENS MAX_MODEL_LEN MAX_NUM_SEQS GPU_MEM
export MAX_TOKENS_64K MAX_MODEL_LEN_64K MAX_NUM_SEQS_64K GPU_MEM_64K DISABLE_CUSTOM_ALL_REDUCE
export N_KNOWLEDGE N_LCB N_HLE N_MM
