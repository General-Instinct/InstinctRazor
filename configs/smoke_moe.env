# configs/smoke_moe.env — single-GPU cross-family MoE smoke recipe (pipelines/smoke_moe.sh).
# Complements smoke_2b.env (dense, linear path only). This runs a small REAL non-Qwen MoE (OLMoE) so the
# generalization the ModelAdapter unlocks is actually exercised: the framework used to quantize ZERO of a
# non-Qwen MoE's experts; the model_type-keyed OlmoeAdapter now quantizes them at EXPERT_BITS.
#
# NOTE: under transformers 5.x OLMoE's experts are BATCHED into FUSED tensors (experts.gate_up_proj /
# down_proj), the same layout as Qwen3.5 — so they ride the fused expert path. Success signal: quant_save's
# apply_ptq log reports a nonzero "expert tensors" count (16 layers x 2 = 32), vs 0 with the old code.

: "${MODEL:=allenai/OLMoE-1B-7B-0924-Instruct}"   # ~6.9B total / ~1.3B active, separate experts, has chat template
: "${MODEL:=${SMOKE_MODEL:-$MODEL}}"
: "${EXPERT_BITS:=3.0}"                # tags the per-expert Linears (via OlmoeAdapter.flat_spec)
: "${LINEAR_BITS:=4.0}"               # attn / lm_head / embed
: "${GROUP:=128}"
: "${CLIP_STEPS:=8}"                  # fewer than the real recipe (16) — faster smoke
: "${MAX_MEM_GIB:=70}"                # single GPU
: "${MODELS_DIR:=/tmp/moe-lowbit/models}"
: "${OUT:=$MODELS_DIR/smoke_olmoe_q3}"

# Plumbing-only eval (not an accuracy read): confirm the dequant checkpoint reloads + emits JSON.
: "${SMOKE_BENCHMARKS:=mmlu_pro}"
: "${SMOKE_N:=40}"
: "${SMOKE_BUDGET:=2048}"             # OLMoE is not a thinking model -> short budget is fine
: "${TP:=1}"
export MODEL EXPERT_BITS LINEAR_BITS GROUP CLIP_STEPS MAX_MEM_GIB MODELS_DIR OUT SMOKE_BENCHMARKS SMOKE_N SMOKE_BUDGET TP
