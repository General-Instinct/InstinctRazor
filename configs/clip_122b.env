# configs/clip_122b.env — the EXACT recipe that built the shipped q122_ptq3b_clip
# (the model behind every number in results/). Reproduced by pipelines/quantize.sh.
# This is uniform-3b experts + 4b backbone + per-block MSE clip-search. It deliberately does
# NOT use salience-aware allocation — finding F4/F6 (docs/MOE_FINDINGS.md) showed allocation is
# second-order for downstream capability, so uniform is the shipped recipe. The probe/alloc
# tooling that established that is the OPTIONAL research path (see configs/README.md).

: "${MODEL:=Qwen/Qwen3.5-122B-A10B}"   # BF16 teacher; loaded multimodal (vision tower retained)
: "${EXPERT_BITS:=3.0}"                # ALL 256 routed experts, both blocks (gate_up + down), int3 per-block
: "${LINEAR_BITS:=4.0}"                # ALL non-expert nn.Linear + embed/lm_head, int4 per-block
: "${GROUP:=128}"                      # per-block group size along the contraction axis
: "${CLIP_STEPS:=16}"                  # MSE-optimal per-block clip search (linspace 1.0->0.65, 16 steps); 0 = absmax
: "${MAX_MEM_GIB:=72}"                 # per-GPU cap for the device_map="auto" load (4xH100-80GB)
: "${MODELS_DIR:=models}"
: "${OUT:=$MODELS_DIR/q122_ptq3b_clip}"

# PROTECTED / always-on path (stays BF16, never quantized to expert/linear bits):
#   - vision tower      : VISUAL_RE = r"(^|\.)visual\." -> skipped by iter_expert_tensors/iter_quant_linears
#   - router / gate     : Qwen3_5MoeTopKRouter is not an nn.Linear -> never enters iter_quant_linears
#   - all norms         : not matched by either iterator
# Effective footprint of the PACKED recipe ~3.05 effective bits ~= ~47-50 GB (under Gemma-4-A4B's ~52 GB).
# IMPORTANT: quant_save.py writes a DEQUANTIZED bf16 checkpoint (~229 GB on disk) so vLLM can eval the
# *capability ceiling* at full fidelity. _ptq_meta.json now reports the CORRECT packed footprint
# (effective_bits ~3.05 -> ~47 GB): the earlier 16b-expert over-count (experts via default_expert_bits
# were counted at 16b) was fixed in moe_quant.effective_bits. The deployable artifact is still the
# GGUF/llama.cpp pack (see docs/MOE_PIPELINE.md).
export MODEL EXPERT_BITS LINEAR_BITS GROUP CLIP_STEPS MAX_MEM_GIB MODELS_DIR OUT
